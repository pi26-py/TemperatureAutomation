}

//--------------FIREBASE--------------
void sendToFirebase(float tempC, float humi,bool status,bool isArchive,int alertState) {
  if (WiFi.status() != WL_CONNECTED) return;


  time_t last_update = time(nullptr);

  HTTPClient http;

  String url = String(firebaseHost) + "/TempValues/" + ".json?auth=" + firebaseAuth;

  http.begin(url);
  http.addHeader("Content-Type", "application/json");


  String jsonData = "{";
  jsonData += "\"humidity\":" + String(humi,2) + ",";
  jsonData += "\"status\":" + String(status) + ",";
  jsonData += "\"isArchive\":" + String(isArchive) + ",";
  jsonData += "\"alertState\":" + String(alertState) + ",";
  jsonData += "\"lastUpdate\": " + String(last_update) + ",";
  jsonData += "\"temperature\":" + String(tempC,2);
  jsonData += "}";

  int httpResponseCode = http.PATCH(jsonData);

  if (httpResponseCode > 0) {
    Serial.printf("Firebase Updated (%d)\n", httpResponseCode);
  } else {
    Serial.printf("Error: %s\n", http.errorToString(httpResponseCode).c_str());
  }

  http.end();
}


void syncTimeNTP() {
  struct timeval tv = {0, 0};
  settimeofday(&tv, nullptr);  

  configTime(0, 0, "ph.pool.ntp.org", "time.google.com", "time.cloudflare.com");
  
  setenv("TZ", "PST-8", 1);   
  tzset();
  struct tm timeinfo;
  unsigned long start = millis();
  while (!getLocalTime(&timeinfo)) {
    if (millis() - start > 10000) {
      Serial.println("❌ NTP sync failed");
      return;
    }
    delay(100);
  }


}

int getAlertStatus(float tempC)
{
  if (tempC <= 19) return 0;
  else if (tempC <= 22) return 1;
  else return 2;
}
