void setup() {
  // Serial.begin(115200);
    Serial.begin(9600);
  

  display.begin(SSD1306_SWITCHCAPVCC, 0x3C);
  display.clearDisplay();


  showBootLogo();
  connectWiFi();
  syncTimeNTP();
  dht.begin();
}

void loop() {

  float humi = dht.readHumidity();
  float tempC = dht.readTemperature();

  // check if valid
  if (isnan(tempC) || isnan(humi)) {
    Serial.println("Failed to read from DHT!");
    return;
  }

    display.clearDisplay();
    display.setTextColor(WHITE);

    // TEMP
    display.setTextSize(1);
    display.setCursor(0, 0);
    display.print("Temperature");

    display.setTextSize(2);
    display.setCursor(0, 10);
    display.print(tempC, 1);
    display.print("C");

    // HUM
    display.setTextSize(1);
    display.setCursor(0, 32);
    display.print("Humidity");

    display.setTextSize(2);
    display.setCursor(0, 42);
    display.print(humi, 1);
    display.print("%");

    //WIFI INDICATOR
    int rssi = WiFi.RSSI();

    display.setTextSize(1);

    display.setCursor(98, 0);
    display.print("WiFi");

    // Icon / Status
    if (WiFi.isConnected()) {
      display.drawBitmap(84, 0, wifi_icon, 8, 8, WHITE);
    } else {
      display.setCursor(84, 0);
      display.print("OFF");
    }


    display.setCursor(84, 10);
    if (rssi > -50) {
      display.print("Strong");
    } else if (rssi > -70) {
      display.print("Mid");
    } else {
      display.print("Weak");
    }

    display.display();

    bool status = true;
    bool isArchive = false;

    int alertState = getAlertStatus(tempC);

    Serial.print("Humidity: ");
    Serial.print(humi);
    Serial.print("%  |  Temperature: ");
    Serial.print(tempC);
    Serial.println(" °C");


  sendToFirebase(tempC, humi,status,isArchive,alertState);

  delay(2000); // update every 2 seconds
}

